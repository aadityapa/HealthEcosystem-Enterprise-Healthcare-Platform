// ─── DEVICE SCHEMA ───────────────────────────────────────────────────────────

enum DeviceVendor {
  ROCHE
  ABBOTT
  SIEMENS
  SYSMEX
  BECKMAN_COULTER
  GENERIC

  @@schema("device")
}

enum DeviceProtocol {
  ASTM
  HL7_V2
  FHIR
  DICOM
  PROPRIETARY

  @@schema("device")
}

enum DeviceStatus {
  ONLINE
  OFFLINE
  ERROR
  MAINTENANCE
  DECOMMISSIONED

  @@schema("device")
}

enum ConnectionType {
  TCP
  SERIAL
  MLLP
  HTTP
  HTTPS
  FILE

  @@schema("device")
}

enum MessageParseStatus {
  PENDING
  PARSING
  PARSED
  FAILED
  RETRYING
  DLQ

  @@schema("device")
}

enum QueueItemStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  DLQ

  @@schema("device")
}

enum DeviceEventType {
  CONNECTED
  DISCONNECTED
  MESSAGE_RECEIVED
  MESSAGE_PARSED
  MESSAGE_FAILED
  RESULT_IMPORTED
  HEARTBEAT
  ERROR
  CONFIG_CHANGED
  CERTIFICATE_EXPIRING

  @@schema("device")
}

model Device {
  id               String         @id @default(uuid()) @db.Uuid
  tenantId         String         @map("tenant_id") @db.Uuid
  organizationId   String         @map("organization_id") @db.Uuid
  branchId         String         @map("branch_id") @db.Uuid
  deviceCode       String         @map("device_code") @db.VarChar(64)
  name             String         @db.VarChar(255)
  vendor           DeviceVendor
  model            String?        @db.VarChar(128)
  serialNumber     String?        @map("serial_number") @db.VarChar(128)
  protocol         DeviceProtocol
  connectionType   ConnectionType @map("connection_type")
  connectionConfig Json           @default("{}") @map("connection_config")
  firmwareVersion  String?        @map("firmware_version") @db.VarChar(32)
  softwareVersion  String?        @map("software_version") @db.VarChar(32)
  status           DeviceStatus   @default(OFFLINE)
  lastSeenAt       DateTime?      @map("last_seen_at") @db.Timestamptz
  isActive         Boolean        @default(true) @map("is_active")
  metadata         Json           @default("{}")
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  adapters    DeviceAdapter[]
  connections DeviceConnection[]
  messages    DeviceMessage[]
  logs        DeviceLog[]
  events      DeviceEvent[]
  health      DeviceHealth[]
  certificates DeviceCertificate[]
  resultQueue ResultQueueItem[]

  @@unique([tenantId, deviceCode])
  @@index([tenantId, branchId])
  @@index([tenantId, status])
  @@map("devices")
  @@schema("device")
}

