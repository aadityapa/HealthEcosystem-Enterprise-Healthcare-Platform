  @@schema("customer_success")
}

model SupportTicket {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @map("tenant_id") @db.Uuid
  ticketNumber   String       @map("ticket_number") @db.VarChar(32)
  subject        String       @db.VarChar(255)
  description    String?
  priority       String       @default("medium") @db.VarChar(16)
  status         TicketStatus @default(OPEN)
  category       String?      @db.VarChar(64)
  assignedTo     String?      @map("assigned_to") @db.Uuid
  createdBy      String?      @map("created_by") @db.Uuid
  resolvedAt     DateTime?    @map("resolved_at") @db.Timestamptz
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz

  @@unique([tenantId, ticketNumber])
  @@index([tenantId, status])
  @@map("support_tickets")
  @@schema("customer_success")
}

model TrainingCourse {
  id             String   @id @default(uuid()) @db.Uuid
  code           String   @unique @db.VarChar(32)
  title          String   @db.VarChar(255)
  description    String?
  durationMins   Int      @default(30) @map("duration_mins")
  moduleType     String   @map("module_type") @db.VarChar(32)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  enrollments TrainingEnrollment[]

  @@map("training_courses")
  @@schema("customer_success")
}

model TrainingEnrollment {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  courseId       String    @map("course_id") @db.Uuid
  status         String    @default("enrolled") @db.VarChar(16)
  progressPct    Int       @default(0) @map("progress_pct")
  completedAt    DateTime? @map("completed_at") @db.Timestamptz
  enrolledAt     DateTime  @default(now()) @map("enrolled_at") @db.Timestamptz

  course TrainingCourse @relation(fields: [courseId], references: [id])

  @@unique([tenantId, userId, courseId])
  @@map("training_enrollments")
  @@schema("customer_success")
}

// ─── COMMERCIAL SCHEMA ─────────────────────────────────────────────────────────

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED

  @@schema("commercial")
}

model SubscriptionPlan {
  id             String   @id @default(uuid()) @db.Uuid
  code           String   @unique @db.VarChar(32)
  name           String   @db.VarChar(128)
  tier           String   @db.VarChar(32)
  monthlyPrice   Decimal  @map("monthly_price") @db.Decimal(14, 2)
  annualPrice    Decimal? @map("annual_price") @db.Decimal(14, 2)
  maxBranches    Int?     @map("max_branches")
  maxUsers       Int?     @map("max_users")
  features       Json     @default("[]")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  subscriptions TenantSubscription[]

  @@map("subscription_plans")
  @@schema("commercial")
}

model TenantSubscription {
  id             String             @id @default(uuid()) @db.Uuid
  tenantId       String             @unique @map("tenant_id") @db.Uuid
  planId         String             @map("plan_id") @db.Uuid
  status         SubscriptionStatus @default(TRIAL)
  licenseKey     String?            @map("license_key") @db.VarChar(64)
  seats          Int                @default(5)
  startedAt      DateTime           @default(now()) @map("started_at") @db.Timestamptz
  expiresAt      DateTime?          @map("expires_at") @db.Timestamptz
  mrr            Decimal            @default(0) @map("mrr") @db.Decimal(14, 2)

  plan SubscriptionPlan @relation(fields: [planId], references: [id])

  @@map("tenant_subscriptions")
  @@schema("commercial")
}

model Quotation {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String?  @map("tenant_id") @db.Uuid
  quoteNumber    String   @map("quote_number") @db.VarChar(32)
  prospectName   String   @map("prospect_name") @db.VarChar(255)
  prospectEmail  String?  @map("prospect_email") @db.VarChar(255)
  planCode       String?  @map("plan_code") @db.VarChar(32)
  totalAmount    Decimal  @map("total_amount") @db.Decimal(14, 2)
  validUntil     DateTime @map("valid_until") @db.Date
  status         String   @default("draft") @db.VarChar(16)
  lineItems      Json     @default("[]") @map("line_items")
  createdBy      String?  @map("created_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@unique([quoteNumber])
  @@map("quotations")
  @@schema("commercial")
}

model PartnerContract {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  contractNumber String   @map("contract_number") @db.VarChar(32)
  partnerType    String   @map("partner_type") @db.VarChar(32)
  partnerName    String   @map("partner_name") @db.VarChar(255)
  startDate      DateTime @map("start_date") @db.Date
  endDate        DateTime? @map("end_date") @db.Date
  value          Decimal  @db.Decimal(14, 2)
  status         String   @default("active") @db.VarChar(16)
  terms          Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@unique([tenantId, contractNumber])
  @@map("partner_contracts")
  @@schema("commercial")
}

model PartnerAccount {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  accountCode    String   @map("account_code") @db.VarChar(32)
  name           String   @db.VarChar(255)
  partnerType    String   @map("partner_type") @db.VarChar(32)
  contactEmail   String?  @map("contact_email") @db.VarChar(255)
  contactPhone   String?  @map("contact_phone") @db.VarChar(20)
  region         String?  @db.VarChar(64)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@unique([tenantId, accountCode])
  @@map("partner_accounts")
  @@schema("commercial")
}
