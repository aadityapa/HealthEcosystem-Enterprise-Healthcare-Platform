model DeviceMessage {
  id             String             @id @default(uuid()) @db.Uuid
  tenantId       String             @map("tenant_id") @db.Uuid
  organizationId String             @map("organization_id") @db.Uuid
  branchId       String             @map("branch_id") @db.Uuid
  deviceId       String             @map("device_id") @db.Uuid
  protocol       DeviceProtocol
  rawPayload     String             @map("raw_payload")
  parsedPayload  Json?              @map("parsed_payload")
  parseStatus    MessageParseStatus @default(PENDING) @map("parse_status")
  errorMessage   String?            @map("error_message")
  retryCount     Int                @default(0) @map("retry_count")
  maxRetries     Int                @default(5) @map("max_retries")
  sampleBarcode  String?            @map("sample_barcode") @db.VarChar(64)
  messageControlId String?          @map("message_control_id") @db.VarChar(64)
  checksumValid  Boolean?           @map("checksum_valid")
  parsedAt       DateTime?          @map("parsed_at") @db.Timestamptz
  receivedAt     DateTime           @default(now()) @map("received_at") @db.Timestamptz

