generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["core", "master", "patient", "lims", "audit", "device", "billing", "inventory", "qc", "crm", "ehr", "abdm", "analytics", "ai", "field", "radiology", "hrms", "marketplace", "observability", "data", "workflow", "dms", "branding", "agents", "i18n", "security", "compliance", "customer_success", "commercial"]
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum TenantTier {
  STARTER
  PROFESSIONAL
  ENTERPRISE
  FRANCHISE

  @@schema("core")
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  CHURNED

  @@schema("core")
}

enum BranchType {
  HQ
  REGIONAL_LAB
  PROCESSING_LAB
  COLLECTION_CENTER
  FRANCHISE
  CLINIC

  @@schema("core")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
  PENDING_VERIFICATION

  @@schema("core")
}

enum Gender {
  MALE
  FEMALE
  OTHER
  UNKNOWN

  @@schema("core")
}

enum SampleStatus {
  ORDERED
  COLLECTED
  IN_TRANSIT
  RECEIVED
  PROCESSING
  RESULT_PENDING
  VERIFIED
  APPROVED
  REJECTED
  REPORTED
  ARCHIVED

  @@schema("lims")
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  REFUNDED

  @@schema("lims")
}

enum ResultFlag {
  NORMAL
  LOW
  HIGH
  CRITICAL_LOW
  CRITICAL_HIGH
  ABNORMAL
  PANIC

  @@schema("lims")
}

enum ConsentType {
  TREATMENT
  DATA_SHARING
  MARKETING
  ABDM_HIE
  TELECONSULT

  @@schema("patient")
}

enum ConsentStatus {
  PENDING
  GRANTED
  REVOKED
  EXPIRED

  @@schema("patient")
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  RELEASE
  APPROVE
  VOID

  @@schema("audit")
}

enum SessionStatus {
  ACTIVE
  EXPIRED
  REVOKED

  @@schema("core")
}

// ─── CORE SCHEMA ─────────────────────────────────────────────────────────────

model Tenant {
  id          String       @id @default(uuid()) @db.Uuid
  slug        String       @unique @db.VarChar(63)
  name        String       @db.VarChar(255)
  tier        TenantTier   @default(PROFESSIONAL)
  status      TenantStatus @default(TRIAL)
  settings    Json         @default("{}")
  dataRegion  String       @default("ap-south-1") @map("data_region") @db.VarChar(32)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  organizations Organization[]
  users         User[]
  roles         Role[]
  branches      Branch[]

  @@map("tenants")
  @@schema("core")
}

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  legalName String   @map("legal_name") @db.VarChar(255)
  tradeName String?  @map("trade_name") @db.VarChar(255)
  gstin     String?  @db.VarChar(15)
  pan       String?  @db.VarChar(10)
  orgType   String   @default("diagnostic") @map("org_type") @db.VarChar(32)
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  branches Branch[]

  @@unique([tenantId, gstin])
  @@index([tenantId])
  @@map("organizations")
  @@schema("core")
}

model Branch {
  id                 String     @id @default(uuid()) @db.Uuid
  tenantId           String     @map("tenant_id") @db.Uuid
  organizationId     String     @map("organization_id") @db.Uuid
  parentBranchId     String?    @map("parent_branch_id") @db.Uuid
  code               String     @db.VarChar(32)
  name               String     @db.VarChar(255)
  branchType         BranchType @map("branch_type")
  address            Json       @default("{}")
  contact            Json       @default("{}")
  isCollectionCenter Boolean    @default(false) @map("is_collection_center")
  isProcessingLab    Boolean    @default(false) @map("is_processing_lab")
  timezone           String     @default("Asia/Kolkata") @db.VarChar(64)
  isActive           Boolean    @default(true) @map("is_active")
  createdAt          DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  parentBranch Branch?      @relation("BranchHierarchy", fields: [parentBranchId], references: [id])
  childBranches Branch[]    @relation("BranchHierarchy")
  userBranches  UserBranch[]
  userRoles     UserRole[]
  departments   Department[]
  franchiseAgreements FranchiseAgreement[] @relation("FranchiseBranch")
  parentFranchiseAgreements FranchiseAgreement[] @relation("ParentBranch")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([organizationId])
  @@map("branches")
  @@schema("core")
}

model Department {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  branchId       String   @map("branch_id") @db.Uuid
  code           String   @db.VarChar(32)
  name           String   @db.VarChar(128)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  branch Branch @relation(fields: [branchId], references: [id])

  @@unique([tenantId, branchId, code])
  @@index([tenantId])
  @@map("departments")
  @@schema("core")
}

model FranchiseAgreement {
  id                String    @id @default(uuid()) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  organizationId    String    @map("organization_id") @db.Uuid
  franchiseBranchId String    @map("franchise_branch_id") @db.Uuid
  parentBranchId    String    @map("parent_branch_id") @db.Uuid
  agreementNumber   String    @map("agreement_number") @db.VarChar(32)
  revenueSharePct   Decimal?  @map("revenue_share_pct") @db.Decimal(5, 2)
  canSetPricing     Boolean   @default(false) @map("can_set_pricing")
  canProcessLocal   Boolean   @default(false) @map("can_process_local")
  canReleaseReports Boolean   @default(false) @map("can_release_reports")
  brandingConfig    Json      @default("{}") @map("branding_config")
  effectiveFrom     DateTime  @map("effective_from") @db.Date
  effectiveTo       DateTime? @map("effective_to") @db.Date
  status            String    @default("active") @db.VarChar(32)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz

  franchiseBranch Branch @relation("FranchiseBranch", fields: [franchiseBranchId], references: [id])
  parentBranch    Branch @relation("ParentBranch", fields: [parentBranchId], references: [id])

  @@unique([tenantId, agreementNumber])
  @@index([tenantId])
  @@map("franchise_agreements")
  @@schema("core")
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  tenantId     String     @map("tenant_id") @db.Uuid
  organizationId String?  @map("organization_id") @db.Uuid
  email        String     @db.VarChar(255)
  phone        String?    @db.VarChar(20)
  passwordHash String?    @map("password_hash") @db.VarChar(255)
  firstName    String     @map("first_name") @db.VarChar(100)
  lastName     String?    @map("last_name") @db.VarChar(100)
  status       UserStatus @default(PENDING_VERIFICATION)
  mfaEnabled   Boolean    @default(false) @map("mfa_enabled")
  mfaSecret    String?    @map("mfa_secret")
  lastLoginAt  DateTime?  @map("last_login_at") @db.Timestamptz
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  userRoles    UserRole[]
  userBranches UserBranch[]
  sessions     UserSession[]
  mfaDevices   MfaDevice[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
  @@schema("core")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String?  @map("tenant_id") @db.Uuid
  code        String   @db.VarChar(64)
  name        String   @db.VarChar(128)
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant          Tenant?          @relation(fields: [tenantId], references: [id])
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([tenantId, code])
  @@map("roles")
  @@schema("core")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique @db.VarChar(128)
  module      String   @db.VarChar(64)
  action      String   @db.VarChar(32)
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  rolePermissions RolePermission[]

  @@map("permissions")
  @@schema("core")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
  @@schema("core")
}

model UserRole {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  branchId  String?  @map("branch_id") @db.Uuid
  grantedAt DateTime @default(now()) @map("granted_at") @db.Timestamptz
  grantedBy String?  @map("granted_by") @db.Uuid

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role    @relation(fields: [roleId], references: [id])
  branch Branch? @relation(fields: [branchId], references: [id])

  @@unique([userId, roleId, branchId])
  @@index([userId])
  @@map("user_roles")
  @@schema("core")
}

model UserBranch {
  userId    String  @map("user_id") @db.Uuid
  branchId  String  @map("branch_id") @db.Uuid
  isPrimary Boolean @default(false) @map("is_primary")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([userId, branchId])
  @@map("user_branches")
  @@schema("core")
}

model UserSession {
  id           String        @id @default(uuid()) @db.Uuid
  tenantId     String        @map("tenant_id") @db.Uuid
  userId       String        @map("user_id") @db.Uuid
  refreshToken String        @unique @map("refresh_token") @db.VarChar(512)
  status       SessionStatus @default(ACTIVE)
  ipAddress    String?       @map("ip_address") @db.VarChar(45)
  userAgent    String?       @map("user_agent")
  deviceId     String?       @map("device_id") @db.VarChar(128)
  deviceName   String?       @map("device_name") @db.VarChar(255)
  expiresAt    DateTime      @map("expires_at") @db.Timestamptz
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz
  revokedAt    DateTime?     @map("revoked_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@map("user_sessions")
  @@schema("core")
}

model MfaDevice {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  type       String   @db.VarChar(32)
  secret     String
  isVerified Boolean  @default(false) @map("is_verified")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("mfa_devices")
  @@schema("core")
}

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique @db.VarChar(128)
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  usedAt    DateTime? @map("used_at") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([userId])
  @@map("password_reset_tokens")
  @@schema("core")
}

// ─── PATIENT SCHEMA ──────────────────────────────────────────────────────────

model Patient {
  id                 String   @id @default(uuid()) @db.Uuid
  tenantId           String   @map("tenant_id") @db.Uuid
  organizationId     String   @map("organization_id") @db.Uuid
  branchId           String   @map("branch_id") @db.Uuid
  uhid               String   @db.VarChar(32)
  firstName          String   @map("first_name") @db.VarChar(100)
  middleName         String?  @map("middle_name") @db.VarChar(100)
  lastName           String?  @map("last_name") @db.VarChar(100)
  dateOfBirth        DateTime? @map("date_of_birth") @db.Date
  gender             Gender   @default(UNKNOWN)
  bloodGroup         String?  @map("blood_group") @db.VarChar(5)
  email              String?  @db.VarChar(255)
  phone              String   @db.VarChar(20)
  alternatePhone     String?  @map("alternate_phone") @db.VarChar(20)
  address            Json     @default("{}")
  abhaNumber         String?  @map("abha_number") @db.VarChar(64)
  abhaAddress        String?  @map("abha_address") @db.VarChar(128)
  photoUrl           String?  @map("photo_url")
  metadata           Json     @default("{}")
  status             String   @default("active") @db.VarChar(32)
  registeredBranchId String?  @map("registered_branch_id") @db.Uuid
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz
  createdBy          String?  @map("created_by") @db.Uuid

  identifiers  PatientIdentifier[]
  consents     PatientConsent[]
  documents    PatientDocument[]
  visits       PatientVisit[]
  timelineEvents PatientTimelineEvent[]
  familyMembers FamilyMember[]
  labOrders    LabOrder[]

  @@unique([tenantId, uhid])
  @@index([tenantId])
  @@index([tenantId, phone])
  @@index([organizationId])
  @@index([branchId])
  @@map("patients")
  @@schema("patient")
}

model PatientIdentifier {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  organizationId String @map("organization_id") @db.Uuid
  branchId   String    @map("branch_id") @db.Uuid
  patientId  String    @map("patient_id") @db.Uuid
  idType     String    @map("id_type") @db.VarChar(32)
  idValue    String    @map("id_value")
  isPrimary  Boolean   @default(false) @map("is_primary")
  verifiedAt DateTime? @map("verified_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([tenantId])
  @@map("patient_identifiers")
  @@schema("patient")
}

model Family {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  organizationId String  @map("organization_id") @db.Uuid
  branchId      String   @map("branch_id") @db.Uuid
  familyCode    String   @map("family_code") @db.VarChar(32)
  headPatientId String?  @map("head_patient_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  members FamilyMember[]

  @@unique([tenantId, familyCode])
  @@index([tenantId])
  @@map("families")
  @@schema("patient")
}

model FamilyMember {
  id           String @id @default(uuid()) @db.Uuid
  familyId     String @map("family_id") @db.Uuid
  patientId    String @map("patient_id") @db.Uuid
  relationship String @db.VarChar(32)

  family  Family  @relation(fields: [familyId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id])

  @@unique([familyId, patientId])
  @@map("family_members")
  @@schema("patient")
}

model PatientConsent {
  id             String        @id @default(uuid()) @db.Uuid
  tenantId       String        @map("tenant_id") @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  branchId       String        @map("branch_id") @db.Uuid
  patientId      String        @map("patient_id") @db.Uuid
  consentType    ConsentType   @map("consent_type")
  status         ConsentStatus @default(PENDING)
  grantedAt      DateTime?     @map("granted_at") @db.Timestamptz
  expiresAt      DateTime?     @map("expires_at") @db.Timestamptz
  revokedAt      DateTime?     @map("revoked_at") @db.Timestamptz
  abdmArtefact   Json?         @map("abdm_artefact")
  ipAddress      String?       @map("ip_address") @db.VarChar(45)
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([tenantId])
  @@map("patient_consents")
  @@schema("patient")
}

model PatientDocument {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  branchId       String   @map("branch_id") @db.Uuid
  patientId      String   @map("patient_id") @db.Uuid
  documentType   String   @map("document_type") @db.VarChar(64)
  fileName       String   @map("file_name") @db.VarChar(255)
  s3Key          String   @map("s3_key")
  mimeType       String?  @map("mime_type") @db.VarChar(128)
  uploadedBy     String?  @map("uploaded_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@map("patient_documents")
  @@schema("patient")
}

model PatientVisit {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  branchId       String    @map("branch_id") @db.Uuid
  patientId      String    @map("patient_id") @db.Uuid
  visitType      String    @map("visit_type") @db.VarChar(32)
  visitNumber    String    @map("visit_number") @db.VarChar(32)
  checkInAt      DateTime  @default(now()) @map("check_in_at") @db.Timestamptz
  checkOutAt     DateTime? @map("check_out_at") @db.Timestamptz
  status         String    @default("active") @db.VarChar(32)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([tenantId, branchId])
  @@map("patient_visits")
  @@schema("patient")
}

model PatientTimelineEvent {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  branchId       String   @map("branch_id") @db.Uuid
  patientId      String   @map("patient_id") @db.Uuid
  eventType      String   @map("event_type") @db.VarChar(64)
  title          String   @db.VarChar(255)
  description    String?
  referenceType  String?  @map("reference_type") @db.VarChar(64)
  referenceId    String?  @map("reference_id") @db.Uuid
  occurredAt     DateTime @map("occurred_at") @db.Timestamptz
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, occurredAt(sort: Desc)])
  @@map("patient_timeline_events")
  @@schema("patient")
}

model UhidSequence {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  branchId String @map("branch_id") @db.Uuid
  prefix   String @db.VarChar(16)
  lastSeq  Int    @default(0) @map("last_seq")

  @@unique([tenantId, branchId])
  @@map("uhid_sequences")
  @@schema("patient")
}

// ─── MASTER / LIMS SCHEMA ────────────────────────────────────────────────────

model TestCategory {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  code           String   @db.VarChar(32)
  name           String   @db.VarChar(128)
  parentId       String?  @map("parent_id") @db.Uuid
  sortOrder      Int      @default(0) @map("sort_order")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  parent   TestCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children TestCategory[] @relation("CategoryHierarchy")
  tests    TestMaster[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("test_categories")
  @@schema("master")
}

model TestMaster {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  categoryId      String   @map("category_id") @db.Uuid
  code            String   @db.VarChar(32)
  name            String   @db.VarChar(255)
  shortName       String?  @map("short_name") @db.VarChar(64)
  specimenType    String   @map("specimen_type") @db.VarChar(32)
  containerType   String?  @map("container_type") @db.VarChar(32)
  tatHours        Int      @default(24) @map("tat_hours")
  methodology     Json     @default("{}")
  referenceRanges Json     @default("[]") @map("reference_ranges")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  category   TestCategory    @relation(fields: [categoryId], references: [id])
  parameters TestParameter[]
  pricing    TestPricing[]
  packageTests PackageTest[]
  orderItems LabOrderItem[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("test_masters")
  @@schema("master")
}

model TestParameter {
  id            String @id @default(uuid()) @db.Uuid
  tenantId      String @map("tenant_id") @db.Uuid
  organizationId String @map("organization_id") @db.Uuid
  testId        String @map("test_id") @db.Uuid
  code          String @db.VarChar(32)
  name          String @db.VarChar(128)
  unit          String? @db.VarChar(32)
  dataType      String @default("numeric") @map("data_type") @db.VarChar(16)
  decimalPlaces Int?   @default(2) @map("decimal_places")
  sortOrder     Int    @default(0) @map("sort_order")

