// ─── BILLING SCHEMA ──────────────────────────────────────────────────────────

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  VOID
  REFUNDED
  OVERDUE

  @@schema("billing")
}

enum InvoiceType {
  LAB
  OPD
  HOME_COLLECTION
  CORPORATE
  INSURANCE
  FRANCHISE
  PACKAGE
  PROFILE
  URGENT

  @@schema("billing")
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  NETBANKING
  WALLET
  CHEQUE
  INSURANCE
  CORPORATE
  RAZORPAY
  CASHFREE
  PAYU

  @@schema("billing")
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  REFUNDED
  CANCELLED

  @@schema("billing")
}

enum ClaimStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  PARTIALLY_APPROVED
  REJECTED
  SETTLED
  RECONCILED

  @@schema("billing")
}

enum SettlementStatus {
  PENDING
  CALCULATED
  APPROVED
  PAID
  DISPUTED

  @@schema("billing")
}

enum GstType {
  CGST_SGST
  IGST
  EXEMPT

  @@schema("billing")
}

model Invoice {
  id               String        @id @default(uuid()) @db.Uuid
  tenantId         String        @map("tenant_id") @db.Uuid
  organizationId   String        @map("organization_id") @db.Uuid
  branchId         String        @map("branch_id") @db.Uuid
  patientId        String?       @map("patient_id") @db.Uuid
  corporateClientId String?      @map("corporate_client_id") @db.Uuid
  invoiceNumber    String        @map("invoice_number") @db.VarChar(32)
  invoiceType      InvoiceType   @map("invoice_type")
  status           InvoiceStatus @default(DRAFT)
  referenceType    String?       @map("reference_type") @db.VarChar(32)
  referenceId      String?       @map("reference_id") @db.Uuid
  subtotal         Decimal       @default(0) @db.Decimal(14, 2)
  discountAmount   Decimal       @default(0) @map("discount_amount") @db.Decimal(14, 2)
  taxableAmount    Decimal       @default(0) @map("taxable_amount") @db.Decimal(14, 2)
  cgstAmount       Decimal       @default(0) @map("cgst_amount") @db.Decimal(14, 2)
  sgstAmount       Decimal       @default(0) @map("sgst_amount") @db.Decimal(14, 2)
  igstAmount       Decimal       @default(0) @map("igst_amount") @db.Decimal(14, 2)
  cessAmount       Decimal       @default(0) @map("cess_amount") @db.Decimal(14, 2)
  totalAmount      Decimal       @default(0) @map("total_amount") @db.Decimal(14, 2)
  paidAmount       Decimal       @default(0) @map("paid_amount") @db.Decimal(14, 2)
  balanceAmount    Decimal       @default(0) @map("balance_amount") @db.Decimal(14, 2)
  gstin            String?       @db.VarChar(15)
  placeOfSupply    String?       @map("place_of_supply") @db.VarChar(64)
  gstType          GstType?      @map("gst_type")
  dueDate          DateTime?     @map("due_date") @db.Date
  issuedAt         DateTime?     @map("issued_at") @db.Timestamptz
  voidedAt         DateTime?     @map("voided_at") @db.Timestamptz
  voidReason       String?       @map("void_reason")
  notes            String?
  metadata         Json          @default("{}")
  createdBy        String?       @map("created_by") @db.Uuid
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  lines            InvoiceLine[]
  payments         Payment[]
  claims           InsuranceClaim[]
  gstLines         GstLine[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId, status])
  @@index([patientId])
  @@index([corporateClientId])
  @@index([branchId, createdAt(sort: Desc)])
  @@map("invoices")
  @@schema("billing")
}

model InvoiceLine {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  branchId       String   @map("branch_id") @db.Uuid
  invoiceId      String   @map("invoice_id") @db.Uuid
  lineType       String   @map("line_type") @db.VarChar(32)
  itemCode       String?  @map("item_code") @db.VarChar(32)
  description    String   @db.VarChar(255)
  hsnSacCode     String?  @map("hsn_sac_code") @db.VarChar(16)
  quantity       Decimal  @default(1) @db.Decimal(10, 2)
  unitPrice      Decimal  @map("unit_price") @db.Decimal(14, 2)
  discount       Decimal  @default(0) @db.Decimal(14, 2)
  taxableAmount  Decimal  @map("taxable_amount") @db.Decimal(14, 2)
  cgstRate       Decimal  @default(0) @map("cgst_rate") @db.Decimal(5, 2)
  sgstRate       Decimal  @default(0) @map("sgst_rate") @db.Decimal(5, 2)
  igstRate       Decimal  @default(0) @map("igst_rate") @db.Decimal(5, 2)
  cgstAmount     Decimal  @default(0) @map("cgst_amount") @db.Decimal(14, 2)
  sgstAmount     Decimal  @default(0) @map("sgst_amount") @db.Decimal(14, 2)
  igstAmount     Decimal  @default(0) @map("igst_amount") @db.Decimal(14, 2)
  lineTotal      Decimal  @map("line_total") @db.Decimal(14, 2)
  referenceType  String?  @map("reference_type") @db.VarChar(32)
  referenceId    String?  @map("reference_id") @db.Uuid
  sortOrder      Int      @default(0) @map("sort_order")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_lines")
  @@schema("billing")
}

model Payment {
  id               String        @id @default(uuid()) @db.Uuid
  tenantId         String        @map("tenant_id") @db.Uuid
  organizationId   String        @map("organization_id") @db.Uuid
  branchId         String        @map("branch_id") @db.Uuid
  invoiceId        String        @map("invoice_id") @db.Uuid
  paymentNumber    String        @map("payment_number") @db.VarChar(32)
  method           PaymentMethod
  status           PaymentStatus @default(PENDING)
  amount           Decimal       @db.Decimal(14, 2)
  gatewayProvider  String?       @map("gateway_provider") @db.VarChar(32)
  gatewayOrderId   String?       @map("gateway_order_id") @db.VarChar(128)
  gatewayPaymentId String?       @map("gateway_payment_id") @db.VarChar(128)
  gatewaySignature String?       @map("gateway_signature")
  upiId            String?       @map("upi_id") @db.VarChar(128)
  cardLast4        String?       @map("card_last4") @db.VarChar(4)
  chequeNumber     String?       @map("cheque_number") @db.VarChar(32)
  chequeDate       DateTime?     @map("cheque_date") @db.Date
  bankReference    String?       @map("bank_reference") @db.VarChar(64)
  paidAt           DateTime?     @map("paid_at") @db.Timestamptz
  refundedAt       DateTime?     @map("refunded_at") @db.Timestamptz
  refundAmount     Decimal?      @map("refund_amount") @db.Decimal(14, 2)
  metadata         Json          @default("{}")
  createdBy        String?       @map("created_by") @db.Uuid
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz

  invoice      Invoice              @relation(fields: [invoiceId], references: [id])
  transactions PaymentTransaction[]

  @@unique([tenantId, paymentNumber])
  @@index([invoiceId])
  @@index([tenantId, status])
  @@map("payments")
  @@schema("billing")
}

model PaymentTransaction {
  id              String        @id @default(uuid()) @db.Uuid
  tenantId        String        @map("tenant_id") @db.Uuid
  paymentId       String        @map("payment_id") @db.Uuid
  transactionType String        @map("transaction_type") @db.VarChar(32)
  status          PaymentStatus
  amount          Decimal       @db.Decimal(14, 2)
  gatewayResponse Json?         @map("gateway_response")
  errorMessage    String?       @map("error_message")
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@map("payment_transactions")
  @@schema("billing")
}

model CorporateClient {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  organizationId   String   @map("organization_id") @db.Uuid
  code             String   @db.VarChar(32)
  name             String   @db.VarChar(255)
  legalName        String?  @map("legal_name") @db.VarChar(255)
  gstin            String?  @db.VarChar(15)
  pan              String?  @db.VarChar(10)
  contactPerson    String?  @map("contact_person") @db.VarChar(128)
  email            String?  @db.VarChar(255)
  phone            String?  @db.VarChar(20)
  address          Json     @default("{}")
  billingCycle     String   @default("monthly") @map("billing_cycle") @db.VarChar(16)
  paymentTermsDays Int      @default(30) @map("payment_terms_days")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz

  contracts   CorporateContract[]
  creditLimit CreditLimit?
  statements  MonthlyStatement[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("corporate_clients")
  @@schema("billing")
}

model CorporateContract {
  id                String    @id @default(uuid()) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  organizationId    String    @map("organization_id") @db.Uuid
  corporateClientId String    @map("corporate_client_id") @db.Uuid
  contractNumber    String    @map("contract_number") @db.VarChar(32)
  rateCardId        String?   @map("rate_card_id") @db.Uuid
  discountPercent   Decimal   @default(0) @map("discount_percent") @db.Decimal(5, 2)
  creditLimit       Decimal?  @map("credit_limit") @db.Decimal(14, 2)
  terms             Json      @default("{}")
  effectiveFrom     DateTime  @map("effective_from") @db.Date
  effectiveTo       DateTime? @map("effective_to") @db.Date
  status            String    @default("active") @db.VarChar(32)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz

  corporateClient CorporateClient @relation(fields: [corporateClientId], references: [id])

  @@unique([tenantId, contractNumber])
  @@index([corporateClientId])
  @@map("corporate_contracts")
  @@schema("billing")
}

model CreditLimit {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  corporateClientId String   @unique @map("corporate_client_id") @db.Uuid
  creditLimit       Decimal  @map("credit_limit") @db.Decimal(14, 2)
  usedAmount        Decimal  @default(0) @map("used_amount") @db.Decimal(14, 2)
  availableAmount   Decimal  @map("available_amount") @db.Decimal(14, 2)
  alertThreshold    Decimal? @map("alert_threshold") @db.Decimal(5, 2)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz

  corporateClient CorporateClient @relation(fields: [corporateClientId], references: [id])

  @@map("credit_limits")
  @@schema("billing")
}

model InsuranceTPA {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  code           String   @db.VarChar(32)
  name           String   @db.VarChar(255)
  contactEmail   String?  @map("contact_email") @db.VarChar(255)
  contactPhone   String?  @map("contact_phone") @db.VarChar(20)
  apiEndpoint    String?  @map("api_endpoint")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  claims InsuranceClaim[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("insurance_tpas")
  @@schema("billing")
}

model InsuranceClaim {
  id               String      @id @default(uuid()) @db.Uuid
  tenantId         String      @map("tenant_id") @db.Uuid
  organizationId   String      @map("organization_id") @db.Uuid
  branchId         String      @map("branch_id") @db.Uuid
  invoiceId        String      @map("invoice_id") @db.Uuid
  tpaId            String      @map("tpa_id") @db.Uuid
  claimNumber      String      @map("claim_number") @db.VarChar(32)
  policyNumber     String      @map("policy_number") @db.VarChar(64)
  patientId        String      @map("patient_id") @db.Uuid
  claimedAmount    Decimal     @map("claimed_amount") @db.Decimal(14, 2)
  approvedAmount   Decimal?    @map("approved_amount") @db.Decimal(14, 2)
  settledAmount    Decimal?    @map("settled_amount") @db.Decimal(14, 2)
  status           ClaimStatus @default(DRAFT)
  submittedAt      DateTime?   @map("submitted_at") @db.Timestamptz
  approvedAt       DateTime?   @map("approved_at") @db.Timestamptz
  settledAt        DateTime?   @map("settled_at") @db.Timestamptz
  rejectionReason  String?     @map("rejection_reason")
  metadata         Json        @default("{}")
  createdAt        DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  invoice Invoice      @relation(fields: [invoiceId], references: [id])
  tpa     InsuranceTPA @relation(fields: [tpaId], references: [id])
  lines   ClaimLine[]

  @@unique([tenantId, claimNumber])
  @@index([invoiceId])
  @@index([tenantId, status])
  @@map("insurance_claims")
  @@schema("billing")
}

model ClaimLine {
  id          String  @id @default(uuid()) @db.Uuid
  claimId     String  @map("claim_id") @db.Uuid
  description String  @db.VarChar(255)
  amount      Decimal @db.Decimal(14, 2)
  approvedAmount Decimal? @map("approved_amount") @db.Decimal(14, 2)

  claim InsuranceClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId])
  @@map("claim_lines")
  @@schema("billing")
}

model FranchiseSettlement {
