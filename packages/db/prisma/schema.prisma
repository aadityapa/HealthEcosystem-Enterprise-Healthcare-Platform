  franchiseBranchId String   @map("franchise_branch_id") @db.Uuid
  revenueSharePct   Decimal  @map("revenue_share_pct") @db.Decimal(5, 2)
  royaltyPct        Decimal  @default(0) @map("royalty_pct") @db.Decimal(5, 2)
  commissionPct     Decimal  @default(0) @map("commission_pct") @db.Decimal(5, 2)
  effectiveFrom     DateTime @map("effective_from") @db.Date
  effectiveTo       DateTime? @map("effective_to") @db.Date
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([tenantId, franchiseBranchId])
  @@map("revenue_share_rules")
  @@schema("billing")
}

model GstLine {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  invoiceId      String   @map("invoice_id") @db.Uuid
  hsnSacCode     String   @map("hsn_sac_code") @db.VarChar(16)
  taxableValue   Decimal  @map("taxable_value") @db.Decimal(14, 2)
